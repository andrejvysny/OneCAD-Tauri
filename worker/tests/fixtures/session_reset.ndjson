{"expect":{"v":1,"t":"resp","id":3,"ok":true,"result":{"documentRevision":0,"workerEpoch":4,"snapshotId":0,"hasScratch":false,"historyPrefixHash":"e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"}}}
